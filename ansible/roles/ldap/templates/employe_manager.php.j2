    <script>
        const departements = <?php echo json_encode($departements); ?>;
        
        function updatePostes() {
            const dept = document.getElementById('departement').value;
            const posteSelect = document.getElementById('poste');
            posteSelect.innerHTML = '<option value="">Sélectionner un poste</option>';
            
            if (dept && departements[dept]) {
                for (const [key, value] of Object.entries(departements[dept].postes)) {
                    const option = document.createElement('option');
                    option.value = value;
                    option.textContent = value;
                    posteSelect.appendChild(option);
                }
            }
        }
        
        function generateBadge(uid) {
            alert(`Génération du badge pour: ${uid}\n\nCette fonctionnalité créera un QR code et un badge RFID pour l'employé.`);
        }
