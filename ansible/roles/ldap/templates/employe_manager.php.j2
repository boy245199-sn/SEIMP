// Fonction pour générer un UID
function generate_uid($prenom, $nom, $departement) {
    $uid = strtolower(substr($prenom, 0, 1) . $nom);
    $uid = preg_replace('/[^a-z0-9]/', '', $uid);
    $uid = substr($uid, 0, 20);
    return $uid;
}

// Fonction pour ajouter un employé dans LDAP
function add_employee_to_ldap($ldapconn, $data, $base_dn) {
    $dn = "uid=" . $data['uid'] . ",ou=people," . $base_dn;
    
    $info = [
        "objectClass" => ["inetOrgPerson", "posixAccount", "shadowAccount"],
        "uid" => $data['uid'],
        "sn" => $data['nom'],
        "givenName" => $data['prenom'],
        "cn" => $data['prenom'] . " " . $data['nom'],
        "displayName" => $data['poste'] . " - " . $data['departement'],
        "uidNumber" => $data['uidNumber'],
        "gidNumber" => $data['gidNumber'],
        "homeDirectory" => "/home/" . $data['uid'],
        "userPassword" => "{SSHA}" . base64_encode(pack("H*", sha1($data['password'] . "salt")) . "salt"),
        "loginShell" => "/bin/bash",
        "title" => $data['poste'],
        "department" => $data['departement'],
        "telephoneNumber" => $data['telephone'],
        "mail" => $data['email'],
        "mobile" => $data['mobile'],
        "description" => $data['description']
    ];
    
    return ldap_add($ldapconn, $dn, $info);
}

// Traitement du formulaire
$message = "";
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $data = [
        'prenom' => $_POST['prenom'],
        'nom' => $_POST['nom'],
        'poste' => $_POST['poste'],
        'departement' => $_POST['departement'],
        'email' => $_POST['email'],
        'telephone' => $_POST['telephone'],
        'mobile' => $_POST['mobile'],
        'password' => $_POST['password'],
        'description' => $_POST['description'],
        'uid' => generate_uid($_POST['prenom'], $_POST['nom'], $_POST['departement']),
        'uidNumber' => rand(20000, 30000),
        'gidNumber' => $departements[$_POST['departement']]['gid']
    ];
    
    if (add_employee_to_ldap($ldapconn, $data, "dc=nodomain")) {
        $message = '<div class="alert alert-success">✅ Employé ajouté avec succès ! UID: ' . $data['uid'] . '</div>';
    } else {
        $message = '<div class="alert alert-danger">❌ Erreur: ' . ldap_error($ldapconn) . '</div>';
    }
}
